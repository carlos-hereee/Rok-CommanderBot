{
	"compilerOptions": {
		/* Language and environment */
		"target": "es2022",
		"module": "ESNext",
		"moduleDetection": "force",
		"moduleResolution": "bundler",

		/* Modules — baseUrl was deprecated in TS 6.0. paths are declared
		   relative to this tsconfig file, which works in TS 5.0+ and is the
		   forward compatible way to keep the same @-prefixed aliases. */
		"paths": {
			"@utils/*": ["./src/utils/*"],
			"@base/*": ["./src/base/*"],
			"@api/*": ["./src/api/*"],
			"@features/*": ["./src/features/*"],
			"@commands/*": ["./src/commands/*"],
			"@db/*": ["./src/db/*"]
		},
		"resolveJsonModule": true,
		"allowArbitraryExtensions": true,

		/* Emit — rootDir is declared explicitly because TS 6.0 no longer infers it
		   silently. without this, tsc prints the "common source directory" warning
		   your screenshot captured. with it, dist/ mirrors the src/ layout exactly. */
		"rootDir": "./src",
		"outDir": "./dist",
		"sourceMap": true,
		"removeComments": true,

		/* Interop */
		"isolatedModules": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,

		/* Type checking — `strict` already implies noImplicitAny + strictNullChecks */
		"strict": true,

		/* Completeness */
		"skipLibCheck": true
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist", "**/*.test.ts", "vitest.config.ts"]
}
