{
	"name": "rok-bot",
	"version": "1.2.3",
	"description": "This is a discord bot, it will be used to display commander builds ie. talent tress",
	"main": "./dist/main.js",
	"scripts": {
		"test": "echo \"Error: no test specified\" && exit 1",
		"start": "node ./dist/main.js",
		"server": "nodemon ./dist/main.js",
		"clean": "rimraf dist",
		"build": "npm run clean && tsc && tsc-alias",
		"deploy": "node ./dist/deploy-commands.js",
		"development": "set NODE_ENV=development&&nodemon ./dist/main.js",
		"lint": "eslint ./src --ext .ts",
		"lint:fix": "eslint ./src --ext .ts --fix",
		"postinstall": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
		"watch:1": "tsc -p tsconfig.json --watch",
		"watch:2": "tsc-alias -p tsconfig.json --watch"
	},
	"keywords": [],
	"author": "",
	"type": "module",
	"license": "ISC",
	"dependencies": {
		"cors": "^2.8.6",
		"discord.js": "^14.25.1",
		"dotenv": "^17.2.1",
		"express": "^5.2.1",
		"mongodb": "^6.18.0",
		"mongoose": "^8.17.1",
		"node-cron": "^4.2.1",
		"uuid": "^11.1.0"
	},
	"devDependencies": {
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/node": "^24.3.0",
		"@types/uuid": "^10.0.0",
		"@typescript-eslint/eslint-plugin": "^8.57.2",
		"@typescript-eslint/parser": "^8.57.2",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-prettier": "^5.5.5",
		"fix-esm-import-path": "^1.10.3",
		"nodemon": "^3.1.10",
		"prettier": "^3.8.1",
		"rimraf": "^6.1.2",
		"tsc-alias": "^1.8.16",
		"typescript": "^5.9.2"
	},
	"_moduleAliases": {
		"@utils": "dist/utils",
		"@events": "dist/events",
		"@features": "dist/features",
		"@api": "dist/api",
		"@base": "dist/base",
		"@config": "dist/config"
	}
}
