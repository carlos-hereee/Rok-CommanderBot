	"description": "This is a discord bot, it will be used to display commander builds ie. talent tress",
	"main": "./dist/index.js",
	"scripts": {
		"test": "echo \"Error: no test specified\" && exit 1",
		"start": "node ./dist/index.js",
		"server": "nodemon ./dist/index.js",
		"build": "tsc && tsc-alias",
		"development": "set NODE_ENV=development&&nodemon ./dist/index.js",
		"postinstall": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
