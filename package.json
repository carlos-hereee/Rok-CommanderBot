		"eslint": "^9.33.0",
		"express": "^5.1.0",
		"helmet": "^8.1.0",
		"mongodb": "^6.18.0",
		"mongoose": "^8.17.1",
		"replace-color": "^2.3.0",
		"sun-tzu-quotes": "^1.0.0",
		"uuid": "^11.1.0"
